<Window x:Class="ScanHelper.ScanHelperHubWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScanHelper Hub"
        Height="280"
        Width="420"
        Topmost="True"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ScanHelper Hub"
                   Foreground="White"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <TextBox x:Name="BarcodeBox"
                 Grid.Row="1"
                 Height="40"
                 FontSize="18"
                 VerticalContentAlignment="Center"
                 KeyDown="BarcodeBox_KeyDown"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,10,0,10">

            <CheckBox x:Name="ChkSeal"
                      Content="Пломбування"
                      Foreground="White"
                      FontSize="16"
                      IsChecked="True"
                      VerticalAlignment="Center"/>

            <CheckBox x:Name="ChkLabels"
                      Content="Друк етикеток"
                      Foreground="White"
                      FontSize="16"
                      IsChecked="True"
                      Margin="20,0,0,0"
                      VerticalAlignment="Center"/>

        </StackPanel>

        <TextBlock x:Name="StatusText"
                   Grid.Row="3"
                   Foreground="White"
                   FontSize="14"
                   Text="Готово"/>

    </Grid>
</Window>