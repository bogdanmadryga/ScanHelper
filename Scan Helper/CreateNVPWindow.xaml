<Window x:Class="ScanHelper.CreateNVPWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создать/Редактировать НВП"
        Height="560" Width="520"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Название -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Название НВП" Foreground="White" FontSize="14"/>
            <TextBox x:Name="NVPNameBox" Margin="0,6,0,0" Height="30"/>
        </StackPanel>

        <!-- Добавление позиции -->
        <Border Grid.Row="1" Background="#2D2D30" CornerRadius="8" Padding="12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Штрихкод" Foreground="White"/>
                    <TextBox x:Name="BarcodeBox" Height="30" Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="План" Foreground="White"/>
                    <TextBox x:Name="CountBox" Height="30" Margin="0,6,0,0"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="Добавить"
                        Height="30"
                        Margin="0,22,0,0"
                        Click="AddItem_Click"/>
            </Grid>
        </Border>

        <!-- Таблица -->
        <DataGrid Grid.Row="2"
                  x:Name="ItemsGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  Background="#2D2D30"
                  Foreground="White"
                  GridLinesVisibility="None"
                  RowBackground="#2D2D30"
                  AlternatingRowBackground="#262626"
                  BorderBrush="#3A3A3A"
                  BorderThickness="1">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Штрихкод"
                                    Binding="{Binding Barcode}"
                                    IsReadOnly="True"
                                    Width="*"/>

                <!-- План редактируемый -->
                <DataGridTextColumn Header="План"
                                    Binding="{Binding ExpectedCount, UpdateSourceTrigger=PropertyChanged}"
                                    Width="90"/>

                <DataGridTextColumn Header="Факт"
                                    Binding="{Binding ScannedCount}"
                                    IsReadOnly="True"
                                    Width="90"/>

                <DataGridTextColumn Header="Осталось"
                                    Binding="{Binding Left}"
                                    IsReadOnly="True"
                                    Width="110"/>

                <DataGridTextColumn Header="Перебор"
                                    Binding="{Binding Over}"
                                    IsReadOnly="True"
                                    Width="110"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Margin="0,0,8,0" Content="Удалить выбранное" Click="DeleteSelected_Click"/>
            <Button Grid.Column="1" Margin="0,0,8,0" Content="Обнулить" Click="Clear_Click"/>
            <Button Grid.Column="2" Margin="0,0,8,0" Content="Сохранить" Click="SaveNVP_Click"/>
            <Button Grid.Column="3" Content="Назад" Click="Back_Click"/>
        </Grid>
    </Grid>
</Window>


