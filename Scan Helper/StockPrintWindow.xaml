<Window x:Class="ScanHelper.StockPrintWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Друк по стану складу"
        Width="1300"
        Height="760"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid Margin="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <DockPanel Margin="0,0,0,10">

            <Button Content="← Назад"
                    Width="110"
                    Height="42"
                    FontSize="16"
                    FontWeight="Bold"
                    Click="Back_Click"
                    Margin="0,0,12,0"/>

            <TextBlock Text="Друк по стану складу"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <!-- TOP -->
        <Border Grid.Row="1"
                Background="#2D2D30"
                CornerRadius="12"
                Padding="14"
                Margin="0,0,0,10">

            <StackPanel>

                <WrapPanel VerticalAlignment="Center">

                    <!-- LOAD -->
                    <Button Content="Завантажити Excel"
                            Width="240"
                            Height="54"
                            FontSize="18"
                            FontWeight="Bold"
                            Margin="0,0,14,0"
                            Click="LoadExcel_Click"/>

                    <!-- SEARCH MODE -->
                    <ComboBox x:Name="SearchModeBox"
                              Width="220"
                              Height="54"
                              FontSize="18"
                              SelectedIndex="0"
                              Margin="0,0,14,0">

                        <ComboBoxItem Content="Артикул"/>
                        <ComboBoxItem Content="Штрихкод"/>
                        <ComboBoxItem Content="Назва товару"/>

                    </ComboBox>

                    <!-- SEARCH -->
                    <TextBox x:Name="SearchBox"
                             Width="420"
                             Height="54"
                             FontSize="24"
                             VerticalContentAlignment="Center"
                             TextChanged="SearchBox_TextChanged"/>

                </WrapPanel>

                <!-- INFO -->
                <TextBlock x:Name="InfoText"
                           Foreground="#D0D0D0"
                           FontSize="15"
                           Margin="0,12,0,0"/>

            </StackPanel>

        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- ARTICLES -->
            <DataGrid x:Name="ArticlesGrid"
                      Grid.Column="0"
                      Margin="0,0,12,0"
                      AutoGenerateColumns="False"
                      SelectionChanged="ArticlesGrid_SelectionChanged"
                      Background="#2D2D30"
                      Foreground="White"
                      RowBackground="#3A3A3A"
                      AlternatingRowBackground="#2D2D30"
                      BorderBrush="#2D2D30"
                      GridLinesVisibility="None"
                      FontSize="18"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      IsReadOnly="True">

                <DataGrid.Resources>

                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="16"/>
                    </Style>

                </DataGrid.Resources>

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Знайдені товари"
                                        Binding="{Binding}"
                                        Width="*"/>

                </DataGrid.Columns>

            </DataGrid>

            <!-- RIGHT -->
            <Grid Grid.Column="1">

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- SIZES -->
                <DataGrid x:Name="SizesGrid"
                          AutoGenerateColumns="False"
                          Background="#2D2D30"
                          Foreground="White"
                          RowBackground="#3A3A3A"
                          AlternatingRowBackground="#2D2D30"
                          BorderBrush="#2D2D30"
                          GridLinesVisibility="None"
                          FontSize="18"
                          HeadersVisibility="Column"
                          CanUserAddRows="False">

                    <DataGrid.Resources>

                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="16"/>
                        </Style>

                    </DataGrid.Resources>

                    <DataGrid.Columns>

                        <DataGridCheckBoxColumn Header="Друк"
                                                Binding="{Binding IsSelected}"
                                                Width="100"/>

                        <DataGridTextColumn Header="Розмір"
                                            Binding="{Binding Size}"
                                            Width="180"/>

                        <DataGridTextColumn Header="Кількість"
                                            Binding="{Binding Qty}"
                                            Width="180"/>

                    </DataGrid.Columns>

                </DataGrid>

                <!-- BUTTONS -->
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,14,0,0">

                    <Button Content="ДРУК"
                            Width="210"
                            Height="62"
                            Margin="0,0,14,0"
                            FontSize="20"
                            FontWeight="Bold"
                            Background="#EAEAEA"
                            Foreground="Black"
                            Click="Print_Click"/>

                    <Button Content="ДРУК ТОВ"
                            Width="210"
                            Height="62"
                            FontSize="20"
                            FontWeight="Bold"
                            Background="#EAEAEA"
                            Foreground="Black"
                            Click="PrintBrand_Click"/>

                </StackPanel>

            </Grid>

        </Grid>

    </Grid>
</Window>