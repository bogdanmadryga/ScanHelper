<Window x:Class="ScanHelper.SealWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пломбування товару"
        Width="1200"
        Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ЧАСТЬ -->
        <Grid Grid.Column="0" Margin="0,0,10,0">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Верх -->
            <DockPanel Grid.Row="0" Margin="0,0,0,10">

                <Button Content="← Назад"
                        Width="90"
                        Click="Back_Click"
                        DockPanel.Dock="Left"/>

                <Button x:Name="LoadExcelButton"
                        Content="Завантажити Excel"
                        Width="170"
                        Margin="10,0,0,0"
                        Click="LoadExcel_Click"
                        DockPanel.Dock="Left"/>

                <TextBlock x:Name="TotalCountText"
                           Text="Загальна кількість: 0"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"/>

            </DockPanel>

            <!-- Поле сканирования -->
            <TextBox x:Name="BarcodeInput"
                     Grid.Row="1"
                     Height="40"
                     FontSize="20"
                     Margin="0,0,0,10"
                     KeyDown="BarcodeInput_KeyDown"/>

            <!-- Таблица -->
            <DataGrid x:Name="ItemsGrid"
          Grid.Row="2"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          CellEditEnding="ItemsGrid_CellEditEnding"
          Background="White"
          Foreground="Black"
          RowBackground="White"
          AlternatingRowBackground="#F5F5F5"
          BorderBrush="#D0D0D0"
          BorderThickness="1"
          GridLinesVisibility="All"
          FontSize="18">

    <DataGrid.Resources>

        <Style TargetType="{x:Type DataGridRowHeader}">
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>

        <Style TargetType="{x:Type DataGridCell}">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>

    </DataGrid.Resources>

    <DataGrid.Columns>

        <DataGridTextColumn Header="Артикул"
                            Binding="{Binding Article}"
                            Width="*"/>

        <DataGridTextColumn Header="Розмір"
                            Binding="{Binding Size}"
                            Width="140"/>

        <DataGridTextColumn Header="Штрихкод"
                            Binding="{Binding Barcode}"
                            Width="220"/>

        <DataGridTextColumn Header="Кількість"
                            Binding="{Binding Qty}"
                            Width="140"/>

    </DataGrid.Columns>

</DataGrid>

            <!-- Кнопки -->
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        Margin="0,10,0,0">

                <Button Content="Очистити"
                        Width="140"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="Clear_Click"/>

                <Button Content="Пломбувати"
                        Width="160"
                        Height="35"
                        Click="Seal_Click"/>
                <Button Content="Друк цінників"
        Width="180"
        Height="35"
        Margin="10,0,0,0"
        Click="AutoPrint_Click"/>

            </StackPanel>

        </Grid>

        <!-- Правая часть -->
        <!-- Правая часть -->
        <Grid Grid.Column="1"
      Background="White">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
               Text="Лог сканування"
               Foreground="Black"
               FontSize="18"
               FontWeight="Bold"
               Margin="0,0,0,10"/>

            <ListBox x:Name="LogList"
             Grid.Row="1"
             Background="White"
             Foreground="Black"
             FontSize="16"
             BorderBrush="Black"
             BorderThickness="2">

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Padding" Value="5"/>
                        <Setter Property="BorderBrush" Value="#D0D0D0"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </ListBox.ItemContainerStyle>

            </ListBox>

        </Grid>

    </Grid>

</Window>