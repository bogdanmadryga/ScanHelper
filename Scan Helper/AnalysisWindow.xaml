<Window x:Class="ScanHelper.AnalysisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Аналіз стану складу"
        Width="1100" Height="650"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <Button Content="← Назад"
                    Width="90" Height="35"
                    Click="Back_Click"
                    Margin="0,0,10,0"/>

            <TextBlock Text="Аналіз стану складу (пошук товарів у різних зонах)"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Top panel -->
        <Border Grid.Row="1" Background="#2D2D30" CornerRadius="10" Padding="12" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Content="Завантажити Excel"
                            Width="160" Height="38"
                            Click="LoadExcel_Click"/>

                    <TextBlock x:Name="FilePathText"
                               Grid.Column="1"
                               Margin="12,0,12,0"
                               VerticalAlignment="Center"
                               Foreground="#D0D0D0"
                               Text="Файл не обрано"/>

                    <!-- справа: общая инфа -->
                    <TextBlock x:Name="InfoText"
                               Grid.Column="2"
                               VerticalAlignment="Center"
                               Foreground="#D0D0D0"
                               Text=""/>
                </Grid>

                <!-- Buttons row -->
                <WrapPanel Grid.Row="1" Margin="0,10,0,0">
                    <Button Content="Різні зони"
                            Width="140" Height="34"
                            Margin="0,0,10,0"
                            Click="ShowMixed_Click"/>

                    <Button Content="Пломбування"
                            Width="140" Height="34"
                            Margin="0,0,10,0"
                            Click="ShowPlomb_Click"/>

                    <Button Content="Висячий товар"
                            Width="140" Height="34"
                            Margin="0,0,10,0"
                            Click="ShowHanging_Click"/>

                    <Button Content="Лежачий товар"
                            Width="140" Height="34"
                            Margin="0,0,10,0"
                            Click="ShowLying_Click"/>

                    <Button Content="Не прив’язаний товар"
                            Width="170" Height="34"
                            Click="ShowUnbound_Click"/>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- Grid -->
        <DataGrid x:Name="ResultGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"

                  SelectionUnit="CellOrRowHeader"
                  SelectionMode="Extended"
                  ClipboardCopyMode="ExcludeHeader"

                  Background="#2D2D30"
                  RowBackground="#3A3A3A"
                  AlternatingRowBackground="#2D2D30"
                  GridLinesVisibility="None"
                  BorderBrush="#2D2D30"
                  Foreground="White"
                  FontSize="14">

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontSize" Value="14"/>
                </Style>

                <Style TargetType="DataGridCell">
                    <Setter Property="TextBlock.TextWrapping" Value="Wrap"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Назва товару" Binding="{Binding ProductName}" Width="260"/>
                <DataGridTextColumn Header="Штрихкод" Binding="{Binding Barcode}" Width="160"/>
                <DataGridTextColumn Header="Кількість" Binding="{Binding TotalQty}" Width="90"/>
                <DataGridTextColumn Header="Зони" Binding="{Binding Zones}" Width="220"/>
                <DataGridTextColumn Header="Місця зберігання" Binding="{Binding Locations}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Bottom total -->
        <TextBlock x:Name="TotalQtyText"
                   Grid.Row="3"
                   Margin="6"
                   FontSize="15"
                   FontWeight="Bold"
                   Foreground="White"
                   Text="Сума кількості: 0"/>
    </Grid>
</Window>
