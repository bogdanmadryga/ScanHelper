<Window x:Class="ScanHelper.AllNVPWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Все НВП" Height="500" Width="600"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox x:Name="NVPList" DisplayMemberPath="Name" FontSize="16"
                 Background="White" Foreground="Black"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="Открыть" Width="130" Height="35" Click="Open_Click"/>
            <Button Content="Редактировать" Width="150" Height="35" Margin="10,0,0,0" Click="Edit_Click"/>
            <Button Content="Удалить" Width="110" Height="35" Margin="10,0,0,0" Click="Delete_Click"/>
        </StackPanel>
    </Grid>
</Window>
