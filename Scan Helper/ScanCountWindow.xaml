<Window x:Class="ScanHelper.ScanCountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пересчёт сканером"
        Width="1000"
        Height="600"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ЧАСТЬ -->
        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- верхняя панель -->
                <RowDefinition Height="Auto"/>
                <!-- поле ввода -->
                <RowDefinition Height="*"/>
                <!-- таблица (СКРОЛЛ) -->
                <RowDefinition Height="Auto"/>
                <!-- кнопки -->
            </Grid.RowDefinitions>

            <!-- Верхняя панель -->
            <DockPanel Grid.Row="0" Margin="0,0,0,10">
                <Button Content="← Назад"
                        Width="90"
                        Click="BackButton_Click"
                        DockPanel.Dock="Left"/>

                <TextBlock x:Name="TotalCountText"
                           Text="Общее количество: 0"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>
            </DockPanel>

            <!-- Поле для сканирования -->
            <TextBox x:Name="BarcodeInput"
                     Grid.Row="1"
                     Height="40"
                     FontSize="20"
                     Margin="0,0,0,10"
                     KeyDown="BarcodeInput_KeyDown"/>

            <!-- Таблица (занимает всё место, есть скролл) -->
            <DataGrid x:Name="BarcodeGrid"
                      Grid.Row="2"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserResizeRows="False"
                      CanUserSortColumns="True"

                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      SelectionUnit="FullRow"
                      SelectionMode="Single"

                      Background="#2D2D30"
                      RowBackground="#3A3A3A"
                      AlternatingRowBackground="#2D2D30"
                      GridLinesVisibility="None"
                      BorderThickness="0"
                      FontSize="18"

                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling">

                <DataGrid.Resources>

                    <!-- УБИРАЕМ ЛЕВУЮ СЛУЖЕБНУЮ КОЛОНКУ -->
                    <Style TargetType="{x:Type DataGridRowHeader}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Setter Property="Width" Value="0"/>
                    </Style>

                    <!-- ЯЧЕЙКИ: белый текст + отступы, без рамок -->
                    <Style TargetType="{x:Type DataGridCell}">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Padding" Value="12,6"/>
                    </Style>

                    <!-- СТРОКИ: красиво выделяем строку -->
                    <Style TargetType="{x:Type DataGridRow}">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#4A4A4A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                    <!-- ЗАГОЛОВКИ: белые, с отступами -->
                    <Style TargetType="{x:Type DataGridColumnHeader}">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="#26262A"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="18"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="12,8"/>
                    </Style>

                </DataGrid.Resources>

                <DataGrid.Columns>
                    <!-- Широкий штрихкод -->
                    <DataGridTextColumn Header="Штрихкод"
                                        Binding="{Binding Code}"
                                        IsReadOnly="True"
                                        Width="*"/>

                    <!-- Количество фиксированной ширины + выравнивание -->
                    <DataGridTextColumn Header="Количество"
                                        Binding="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="160">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox">
                                <Setter Property="HorizontalContentAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>

            </DataGrid>

            <!-- Кнопки -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
                <Button Content="Обнулить"
                        Width="120"
                        Click="ResetButton_Click"/>
            </StackPanel>

        </Grid>

        <!-- ПРАВАЯ ЧАСТЬ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Лог сканирования"
                       Foreground="White"
                       FontSize="18"
                       Margin="0,0,0,10"/>

            <ListBox x:Name="LogList"
                     Grid.Row="1"
                     Background="#2D2D30"
                     Foreground="White"
                     FontSize="16"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>
        </Grid>

    </Grid>
</Window>


