<Window x:Class="ScanHelper.PrintOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Друк"
        Height="600"
        Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E1E">

    <Grid Margin="15">

        <StackPanel>

            <TextBlock Text="Друк документів"
                       Foreground="White"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,15"/>

            <!-- ТТН -->
            <GroupBox Header="ТТН 10x10"
                      Foreground="White"
                      Margin="0,0,0,10">

                <StackPanel Margin="10">

                    <TextBlock Text="Принтер"
                               Foreground="White"/>

                    <ComboBox x:Name="TtnPrinterBox"
                              Height="30"
                              Margin="0,5,0,10"/>

                    <TextBlock Text="Кількість"
                               Foreground="White"/>

                    <TextBox x:Name="TtnCopiesBox"
                             Text="2"
                             Height="30"
                             Margin="0,5,0,10"/>

                    <Button Content="Друк ТТН"
                            Height="35"
                            Click="PrintTtn_Click"/>

                </StackPanel>

            </GroupBox>

            

            <!-- А4 -->
            <GroupBox Header="Скрін А4"
                      Foreground="White">

                <StackPanel Margin="10">

                    <TextBlock Text="Принтер"
                               Foreground="White"/>

                    <ComboBox x:Name="A4PrinterBox"
                              Height="30"
                              Margin="0,5,0,10"/>

                    <TextBlock Text="Кількість"
                               Foreground="White"/>

                    <TextBox x:Name="ScreenshotCopiesBox"
                             Text="1"
                             Height="30"
                             Margin="0,5,0,10"/>

                    <Button Content="Друк А4"
                            Height="35"
                            Click="PrintA4_Click"/>

                </StackPanel>

            </GroupBox>

            <Button Content="Закрити"
                    Width="150"
                    Height="40"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0"
                    Click="Cancel_Click"/>

        </StackPanel>

    </Grid>
</Window>