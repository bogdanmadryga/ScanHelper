<Window x:Class="ScanHelper.OfficeInstagramWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Прив’язки: Офіс → Інстаграм"
        Width="1250" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <Button Content="← Назад"
                    Width="90" Height="35"
                    Click="Back_Click"
                    Margin="0,0,10,0"/>

            <TextBlock Text="Штрихкоди без місця в Інстаграм (але є в Офісі)"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <Border Grid.Row="1" Background="#2D2D30" CornerRadius="10" Padding="12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Завантажити Офіс"
                            Width="160" Height="38"
                            Margin="0,0,10,0"
                            Click="LoadOffice_Click"/>

                    <Button Content="Завантажити Інстаграм"
                            Width="190" Height="38"
                            Click="LoadInstagram_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="12,0,12,0">
                    <TextBlock x:Name="OfficePathText"
                               Foreground="#D0D0D0"
                               Text="Офіс: файл не обрано"/>
                    <TextBlock x:Name="InstagramPathText"
                               Foreground="#D0D0D0"
                               Text="Інстаграм: файл не обрано"/>
                </StackPanel>

                <TextBlock x:Name="InfoText"
                           Grid.Column="3"
                           VerticalAlignment="Center"
                           Foreground="#D0D0D0"
                           Text=""/>
            </Grid>
        </Border>

        <DataGrid x:Name="ResultGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionUnit="CellOrRowHeader"
                  SelectionMode="Extended"
                  ClipboardCopyMode="ExcludeHeader"
                  Background="#2D2D30"
                  RowBackground="#3A3A3A"
                  AlternatingRowBackground="#2D2D30"
                  GridLinesVisibility="None"
                  BorderBrush="#2D2D30"
                  Foreground="White"
                  FontSize="14">

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontSize" Value="14"/>
                </Style>

                <Style TargetType="DataGridCell">
                    <Setter Property="TextBlock.TextWrapping" Value="Wrap"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Штрихкод" Binding="{Binding Barcode}" Width="170"/>
                <DataGridTextColumn Header="К-ть (Офіс)" Binding="{Binding OfficeQty}" Width="90"/>
                <DataGridTextColumn Header="Місце (Офіс)" Binding="{Binding OfficeLocations}" Width="260"/>
                <DataGridTextColumn Header="Назва товару" Binding="{Binding ProductName}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3"
                   Margin="2,8,2,0"
                   Foreground="#AFAFAF"
                   Text="Підказка: щоб скопіювати окремо значення — виділи клітинку та Ctrl+C (заголовки не копіюються)."/>
    </Grid>
</Window>