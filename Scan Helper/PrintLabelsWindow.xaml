<Window x:Class="ScanHelper.PrintLabelsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Печать цінників"
        Width="1100"
        Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid Margin="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <DockPanel Margin="0,0,0,10">

            <Button Content="← Назад"
                    Width="100"
                    Height="35"
                    Click="Back_Click"
                    Margin="0,0,10,0"/>

            <TextBlock Text="Печать цінників"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <!-- TOP PANEL -->
        <Border Grid.Row="1"
                Background="#2D2D30"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,0,10">

            <StackPanel>

                <!-- TOP CONTROLS -->
                <WrapPanel Margin="0,0,0,10">

                    <Button Content="Завантажити Excel"
                            Width="180"
                            Height="40"
                            Click="LoadExcel_Click"
                            Margin="0,0,10,0"/>

                    <TextBox x:Name="BarcodeBox"
                             Width="260"
                             Height="40"
                             FontSize="18"
                             VerticalContentAlignment="Center"
                             KeyDown="BarcodeBox_KeyDown"/>

                    <Button Content="Видалити останній"
                            Width="170"
                            Height="40"
                            Margin="10,0,0,0"
                            Click="RemoveLast_Click"/>

                    <Button Content="Очистити"
                            Width="120"
                            Height="40"
                            Margin="10,0,0,0"
                            Click="Clear_Click"/>

                </WrapPanel>

                <!-- PRINT BUTTONS -->
                <StackPanel Orientation="Horizontal">

                    <Button Content="Друк"
            Width="150"
            Height="42"
            FontSize="16"
            FontWeight="Bold"
            Margin="0,0,10,0"
            Click="Print_Click"/>

                    <Button Content="Друк ТОВ"
            Width="150"
            Height="42"
            FontSize="16"
            FontWeight="Bold"
            Margin="0,0,10,0"
            Click="PrintBrand_Click"/>

                    <Button Content="Повторити останній"
            Width="200"
            Height="42"
            FontSize="16"
            FontWeight="Bold"
            Click="RepeatLast_Click"/>

                </StackPanel>

                <!-- INFO -->
                <TextBlock x:Name="FilePathText"
                           Foreground="#CFCFCF"
                           FontSize="13"
                           Margin="0,10,0,5"/>

                <TextBlock x:Name="InfoText"
                           Foreground="#CFCFCF"
                           FontSize="13"
                           Margin="0,0,0,5"/>

                <TextBlock Text="Інструкція: завантаж Excel → скануй штрихкоди → натисни друк"
                           Foreground="#AAAAAA"
                           FontSize="12"/>

            </StackPanel>

        </Border>

        <!-- GRID -->
        <DataGrid x:Name="ResultGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  Background="#2D2D30"
                  Foreground="White"
                  RowBackground="#3A3A3A"
                  AlternatingRowBackground="#2D2D30"
                  BorderBrush="#2D2D30"
                  GridLinesVisibility="None"
                  FontSize="14"
                  IsReadOnly="True"
                  CanUserAddRows="False">

            <DataGrid.Resources>

                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontSize" Value="14"/>
                </Style>

            </DataGrid.Resources>

            <DataGrid.Columns>

                <DataGridTextColumn Header="Штрихкод"
                                    Binding="{Binding Barcode}"
                                    Width="220"/>

                <DataGridTextColumn Header="Артикул"
                                    Binding="{Binding Article}"
                                    Width="*"/>

                <DataGridTextColumn Header="Розмір"
                                    Binding="{Binding Size}"
                                    Width="120"/>

            </DataGrid.Columns>

        </DataGrid>

        <!-- BOTTOM -->
        <Border Grid.Row="3"
                Background="#2D2D30"
                CornerRadius="10"
                Padding="10"
                Margin="0,10,0,0">

            <TextBlock x:Name="CountText"
                       Text="У черзі: 0"
                       Foreground="White"
                       FontSize="16"
                       FontWeight="Bold"/>
        </Border>

    </Grid>
</Window>